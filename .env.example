# =====================================================================
# KUPE — Environment Variables
# Copy this file to backend/.env and frontend/.env.local
# Never commit the real .env files.
# =====================================================================

# ---------- BACKEND (backend/.env) ----------

# GCP Project
GCP_PROJECT_ID=project-8835c3ba-ad0b-4e0b-b56
VERTEX_LOCATION=us-central1

# --- AUTH (Application Default Credentials) ---
# Local dev: do NOT set GOOGLE_APPLICATION_CREDENTIALS. Instead run:
#   gcloud auth login
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project project-8835c3ba-ad0b-4e0b-b56
# Cloud Run: the runtime service account (kupe-backend-sa) is auto-attached, no env var needed.
# (The Free Trial org policy blocks SA key downloads, so we use ADC end-to-end.)

# Gemini model
GEMINI_MODEL=gemini-2.5-pro
# Project access to gemini-3.1-pro-preview is gated; gemini-2.5-pro is the
# stable choice for this account. Update if/when 3.1 Pro becomes available.

# Firebase Admin (for verifying ID tokens server-side)
FIREBASE_PROJECT_ID=project-8835c3ba-ad0b-4e0b-b56

# Maps API (server-side key — restricted to Places API New)
MAPS_SERVER_KEY=

# CORS allowlist (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://project-8835c3ba-ad0b-4e0b-b56.web.app,https://project-8835c3ba-ad0b-4e0b-b56.firebaseapp.com

# App config
APP_ENV=development
LOG_LEVEL=INFO
ENABLE_GROUNDING=true
DYNAMIC_GROUNDING_THRESHOLD=0.3

# ---------- FRONTEND (frontend/.env.local) ----------

VITE_API_BASE_URL=http://localhost:8000

# Firebase Web Config (from Firebase Console → Project Settings → Web App)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=project-8835c3ba-ad0b-4e0b-b56.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=project-8835c3ba-ad0b-4e0b-b56
VITE_FIREBASE_STORAGE_BUCKET=project-8835c3ba-ad0b-4e0b-b56.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Maps JS API (browser key — restricted to Maps JS + your domains)
VITE_MAPS_BROWSER_KEY=

# Default city for demo
VITE_DEFAULT_CITY=Kuala Lumpur
VITE_DEFAULT_LAT=3.1390
VITE_DEFAULT_LNG=101.6869
